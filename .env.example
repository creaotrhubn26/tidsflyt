NODE_ENV=production
PORT=5000

DATABASE_URL=postgresql://user:password@host:5432/tidum
SESSION_SECRET=replace-with-a-long-random-secret
JWT_SECRET=replace-with-a-long-random-secret

APP_BASE_URL=https://tidum.no
APP_URL=https://tidum.no

GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=https://tidum.no/api/auth/google/callback
CF_TURNSTILE_SECRET_KEY=your-cloudflare-turnstile-secret-key
VITE_CF_TURNSTILE_SITE_KEY=your-cloudflare-turnstile-site-key
CREATORHUB_SYNC_WEBHOOK_URL=https://creatorhub-backend.onrender.com/api/admin/tidum-access-requests/sync
TIDUM_CREATORHUB_SYNC_SECRET=replace-with-a-shared-random-secret

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=smtp-user
SMTP_PASS=smtp-password
SMTP_FROM_NAME=Tidum
SMTP_FROM_EMAIL=hello@creatorhubn.com
SMTP_REPLY_TO=hello@creatorhubn.com

MANAGER_EMAIL=hello@creatorhubn.com
GITHUB_TOKEN=

DEFAULT_GA4_MEASUREMENT_ID=G-LTGH4LNPE3
DEFAULT_GA4_STREAM_ID=14316357971
DEFAULT_GTM_CONTAINER_ID=GTM-55SPZGMD
DEFAULT_ENABLE_ANALYTICS=true

# ─── Stripe (alle secrets i Render env, ikke DB) ─────────────────────────
# Hentes fra Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Signing secret per webhook-endpoint (Stripe Dashboard → Developers → Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── GA4 server-side (Measurement Protocol) ──────────────────────────────
# Måle-ID kan også være DEFAULT_GA4_MEASUREMENT_ID over (samme verdi).
# API secret er separat og må opprettes:
# GA4 Admin → Data Streams → din web-stream →
#   Measurement Protocol API secrets → Create
GA4_MEASUREMENT_ID=G-...
GA4_API_SECRET=replace-with-mp-api-secret
